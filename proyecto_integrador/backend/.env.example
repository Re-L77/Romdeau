# Database
# DATABASE_URL: usada por Prisma Client en runtime (puede ser pooler de Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/db_name
# DIRECT_URL: usada por Prisma Migrate/introspeccion (conexion directa)
DIRECT_URL=postgresql://user:password@localhost:5432/db_name

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Opcional: si no se define, la app usa SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Server
PORT=3000

# CORS
CORS_ORIGIN=http://localhost:5173

# URL del frontend para enlaces de recuperación de contraseña (Supabase)
FRONTEND_URL=http://localhost:5173
