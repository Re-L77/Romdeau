/// Tabla para los posibles estados de una auditoría programada
model estados_auditoria_programada {
  id          Int                      @id @db.SmallInt
  nombre      String                   @unique @db.VarChar(50)
  descripcion String?
  auditorias  auditorias_programadas[]
}

/// Tabla para auditorías programadas
model auditorias_programadas {
  id                           String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  titulo                       String                       @db.VarChar(255)
  descripcion                  String?
  fecha_programada             DateTime                     @db.Timestamptz(6)
  fecha_inicio                 DateTime?                    @db.Timestamptz(6)
  fecha_fin                    DateTime?                    @db.Timestamptz(6)
  estado_id                    Int                          @default(1) @db.SmallInt
  auditor_id                   String                       @db.Uuid
  oficina_id                   String?                      @db.Uuid
  estante_id                   String?                      @db.Uuid
  created_at                   DateTime?                    @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime?                    @default(now()) @db.Timestamptz(6)
  estados_auditoria_programada estados_auditoria_programada @relation(fields: [estado_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_aud_estado")
  estantes                     estantes?                    @relation("AuditoriasEstante", fields: [estante_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_aud_estante")
  oficinas                     oficinas?                    @relation("AuditoriasOficina", fields: [oficina_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_aud_oficina")
  usuarios                     usuarios                     @relation("AuditoriasUsuario", fields: [auditor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_aud_usuario")
  logs_auditoria               logs_auditoria[]

  @@index([estado_id], map: "idx_auditorias_estado")
  @@index([auditor_id], map: "idx_auditorias_auditor")
  @@index([oficina_id], map: "idx_auditorias_oficina")
  @@index([estante_id], map: "idx_auditorias_estante")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model activos {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  codigo_etiqueta     String?               @unique
  categoria_id        String                @db.Uuid
  custodio_actual_id  String?               @db.Uuid
  oficina_id          String?               @db.Uuid
  estante_id          String?               @db.Uuid
  especificaciones    Json?                 @default("{}")
  estado_operativo_id Int                   @default(1) @db.SmallInt
  foto_principal_url  String?
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  nombre              String?               @db.VarChar(255)
  categorias          categorias            @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios            usuarios?             @relation(fields: [custodio_actual_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  estados_activo      estados_activo        @relation(fields: [estado_operativo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  estantes            estantes?             @relation(fields: [estante_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  oficinas            oficinas?             @relation(fields: [oficina_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bajas_activos       bajas_activos?
  datos_financieros   datos_financieros?
  logs_auditoria      logs_auditoria[]
  logs_depreciacion   logs_depreciacion[]
  movimientos_activos movimientos_activos[]

  @@index([custodio_actual_id], map: "idx_activos_custodio")
  @@index([estante_id], map: "idx_activos_estante")
  @@index([codigo_etiqueta], map: "idx_activos_etiqueta")
  @@index([oficina_id], map: "idx_activos_oficina")
  @@index([especificaciones], map: "idx_activos_specs", type: Gin)
}

